PORT=5000
NODE_ENV=production

# Configuración de Seguridad y Sesión
JWT_SECRET=tu_jwt_secret_largo_y_seguro

# Base de Datos SQL (PostgreSQL en la nube, ej: Render)
DATABASE_URL=postgres://usuario:password@host.render.com/cooperadora_db

# Base de Datos NoSQL (MongoDB Atlas en la nube)
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/cooperadora_nosql

# Configuración de Correo (API Resend)
RESEND_API_KEY=re_tu_clave_de_api
EMAIL_FROM=onboarding@resend.dev

# Configuración de Integración con Mercado Pago (Producción o Sandbox)
MP_ACCESS_TOKEN=APP_USR-tu_access_token_de_mercado_pago
MP_WEBHOOK_SECRET=tu_webhook_secret_de_mercado_pago_para_validar_firmas
MP_MINIMO_CUOTA=2000

# URLs del Ecosistema en la Nube
FRONTEND_URL=https://tu-app.vercel.app
BACKEND_URL=https://tu-backend.onrender.com
